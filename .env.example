# ================================
# K-Chat runtime provider config
# ================================
# AI_PROVIDER: hf | openai | anthropic
AI_PROVIDER=hf

# Provider API keys
# - hf        -> HF_TOKEN
# - openai    -> OPENAI_API_KEY
# - anthropic -> ANTHROPIC_API_KEY
HF_TOKEN=your_hf_token_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

MODEL_PRESET=high

# Optional fixed model overrides (highest priority)
# If set, these override MODEL_PRESET for each provider.
# HF_MODEL=google/gemma-4-31B-it
# OPENAI_MODEL=gpt-4.1
# ANTHROPIC_MODEL=claude-opus-4-7

# Server bind config
PORT=3000
# HOST=0.0.0.0 lets phone/Tailscale access work
HOST=0.0.0.0
